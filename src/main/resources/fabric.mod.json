{
	"schemaVersion": 1,
	"id": "slowcraft",
	"version": "${version}",
	"name": "Slowcraft",
	"description": "An API for creating low-tech Progressive Crafting items.",
	"authors": [
		"nibbyy"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/slowcraft",
		"sources": "https://github.com/nibbyy/Slowcraft",
		"issues": "https://github.com/nibbyy/Slowcraft/issues"
	},
	"license": "MIT",
	"icon": "assets/slowcraft/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"nibbyy.slowcraft.Slowcraft"
		],
		"client": [
			"nibbyy.slowcraft.client.SlowcraftClient"
		],
		"fabric-datagen": [
			"nibbyy.slowcraft.client.SlowcraftDataGenerator"
		],
		"jei_mod_plugin": [
			"nibbyy.slowcraft.client.compat.jei.JEISlowcraftPlugin"
		]
	},
	"mixins": [
		"slowcraft.mixins.json",
		{
			"config": "slowcraft.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}